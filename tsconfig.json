{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "types": ["node", "vite/client"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": ["./*"],
      "model/*": ["./model/*"],
      "utils/*": ["./utils/*"]
    },
    "noEmit": true
  },
  "include": [
    "*.ts",
    "*.tsx",
    "api/**/*.ts",
    "api/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "docs/**/*.ts",
    "docs/**/*.tsx",
    "services/**/*.ts",
    "services/**/*.tsx",
    "utils/**/*.ts",
    "utils/**/*.tsx",
    "netlify/model/gemini.tsx",
    "netlify/model/modelCallTypes.ts",
    "netlify/utils/**/*.ts",
    "netlify/utils/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "template-routing-lab",
    "vite.config.ts",
    "netlify/functions",
    "netlify/model/openai.tsx",
    "netlify/model/openrouter.tsx",
    "services/localApi.ts",
    "api/lib/services"
  ]
}
